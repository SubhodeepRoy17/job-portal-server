{
    "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "https://job-portal-client-ashen.vercel.app" },
        { "key": "Access-Control-Allow-Methods", "value": "POST,GET,OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type,Authorization" },
        { "key": "Access-Control-Allow-Credentials", "value": "true" }
      ]
    }
  ],
    "version": 2,
    "builds": [
        {
            "src": "Server.js",
            "use": "@vercel/node"
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "/Server.js"
        },
        {
            "src": "/(.*)",
            "dest": "/Server.js"
        }
    ]
}
